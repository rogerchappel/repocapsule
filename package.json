{
  "name": "repocapsule",
  "version": "0.1.0",
  "description": "Sanitized deterministic repo capsule generator for bug reports and agent debugging.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "repocapsule": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test dist/**/*.test.js",
    "smoke": "npm run build && bash tests/cli-smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "bug-report",
    "cli",
    "debugging",
    "git",
    "redaction",
    "repository",
    "reproducible"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
