{
  "name": "repocapsule",
  "version": "0.1.0",
  "description": "Sanitized deterministic repo capsule generator for bug reports and agent debugging.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "bin": {
    "repocapsule": "./dist/src/cli.js"
  },
  "files": [
    "dist/src",
    "examples",
    "fixtures/sample-repo",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test dist/**/*.test.js",
    "smoke": "npm run build && bash tests/cli-smoke.sh",
    "package:smoke": "bash scripts/package-smoke.sh",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "bug-report",
    "cli",
    "debugging",
    "git",
    "redaction",
    "repository",
    "reproducible"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/repocapsule.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/repocapsule/issues"
  },
  "homepage": "https://github.com/rogerchappel/repocapsule#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
